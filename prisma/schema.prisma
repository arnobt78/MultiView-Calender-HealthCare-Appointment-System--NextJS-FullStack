// Doctor Patient Calendar Appointment Management System - Full schema matching existing PostgreSQL migrations
// All tables, UUIDs, foreign keys, and relations for scaling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Users (auth/profile; id from auth system, no default)
model User {
  id                      String    @id @db.Uuid
  email                   String    @db.Text
  role                    String?   @db.Text
  display_name            String?   @db.Text
  image                   String?   @db.Text
  created_at              DateTime  @default(now())
  password_hash           String?   @db.Text
  email_verified         Boolean   @default(false)
  email_verification_token String?  @db.Uuid
  password_reset_token    String?   @db.Uuid
  password_reset_expires   DateTime? @db.Timestamptz(6)
  /// Medical specialty for doctors — e.g. "Cardiology", "Pediatrics"
  specialty               String?   @db.Text
  /// Short biography / intro paragraph for the doctor services page
  bio                     String?   @db.Text

  appointments_owned       Appointment[]           @relation("AppointmentOwner")
  appointments_as_treating_physician Appointment[] @relation("AppointmentTreatingPhysician")
  appointment_assignees   AppointmentAssignee[]   @relation("AssigneeUser")
  appointment_assignees_invited_by AppointmentAssignee[] @relation("AssigneeInvitedBy")
  activities              Activity[]              @relation("ActivityCreatedBy")
  dashboard_access_owned   DashboardAccess[]       @relation("DashboardOwner")
  dashboard_access_invited DashboardAccess[]      @relation("DashboardInvitedUser")
  dashboard_access_invited_by DashboardAccess[]    @relation("DashboardInvitedBy")
  notifications               Notification[]        @relation("UserNotifications")
  google_calendar_token       GoogleCalendarToken?  @relation("UserGoogleCalendar")
  doctor_availabilities       DoctorAvailability[]  @relation("DoctorAvailabilityUser")
  doctor_time_offs            DoctorTimeOff[]       @relation("DoctorTimeOffUser")
  appointment_types_owned     AppointmentType[]     @relation("AppointmentTypeUser")
  patients_created            Patient[]             @relation("PatientCreatedBy")
  patients_updated            Patient[]             @relation("PatientUpdatedBy")
  patients_primary_doctor     Patient[]             @relation("PatientPrimaryDoctor")

  @@map("users")
}

// --- Patients
model Patient {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  firstname   String    @db.Text
  lastname    String    @db.Text
  birth_date  DateTime? @db.Date
  care_level  Int?
  pronoun     String?   @db.Text
  email       String?   @db.Text
  active      Boolean   @default(true)
  active_since DateTime? @db.Timestamptz(6)
  /// Flexible demo/clinical fields (allergies, meds, notes) — merged on PUT, not replaced blindly.
  clinical_profile Json?
  created_by_id     String? @map("created_by") @db.Uuid
  updated_by_id     String? @map("updated_by") @db.Uuid
  primary_doctor_id String? @map("primary_doctor") @db.Uuid

  created_by     User? @relation("PatientCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  updated_by     User? @relation("PatientUpdatedBy", fields: [updated_by_id], references: [id], onDelete: SetNull)
  primary_doctor User? @relation("PatientPrimaryDoctor", fields: [primary_doctor_id], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  relatives      Relative[] @relation("PatientRelatives")

  @@map("patients")
}

// --- Relatives (patient family members / emergency contacts)
model Relative {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  firstname           String    @db.Text
  lastname            String    @db.Text
  pronoun             String?   @db.Text
  notes               String?   @db.Text
  /// Relationship to the patient — e.g. "Mother", "Spouse", "Guardian"
  relationship        String?   @db.Text
  phone               String?   @db.Text
  email               String?   @db.Text
  date_of_birth       DateTime? @db.Date
  /// Marks this relative as an emergency contact for the linked patient
  is_emergency_contact Boolean  @default(false)
  /// Optional link to a patient record
  patient_id          String?   @db.Uuid

  patient Patient? @relation("PatientRelatives", fields: [patient_id], references: [id], onDelete: SetNull)

  @@index([patient_id])
  @@map("relatives")
}

// --- Categories (appointment categories / service types)
model Category {
  id                      String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at              DateTime  @default(now())
  updated_at              DateTime? @db.Timestamptz(6)
  label                   String    @db.Text
  description             String?   @db.Text
  color                   String?   @db.Text
  icon                    String?   @db.Text
  /// Whether this category is shown as an active service offering
  is_active               Boolean   @default(true)
  /// Controls display order in listings (lower = shown first)
  sort_order              Int       @default(0)
  /// Default appointment duration in minutes for this service type
  duration_minutes_default Int?

  appointments Appointment[]

  @@map("categories")
}

// --- Appointments (DB: patient, category; physical column `user_id` = calendar owner — Prisma field is `owner_id` (B3).)
// B2: optional `treating_physician_id` = clinical FK. API JSON still exposes `user_id` via serializers for stable clients.
model Appointment {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at  DateTime  @default(now())
  updated_at  DateTime? @db.Timestamptz(6)
  start       DateTime  @db.Timestamptz(6)
  end         DateTime  @db.Timestamptz(6)
  location    String?   @db.Text
  patient_id  String?   @map("patient") @db.Uuid
  category_id String?   @map("category") @db.Uuid
  notes       String?   @db.Text
  title       String    @db.Text
  status      String?   @db.Text // 'done' | 'pending' | 'alert'
  /// Calendar owner — maps to DB column `user_id` (B3: Prisma name `owner_id` only; no migration).
  owner_id    String    @map("user_id") @db.Uuid
  /// B2: optional treating / referring physician; display rule: `treating_physician_id ?? owner_id` (see `appointment-display-doctor.ts`).
  treating_physician_id String? @db.Uuid
  attachments String[] @default([])

  patient     Patient?   @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  category    Category?  @relation(fields: [category_id], references: [id], onDelete: SetNull)
  owner       User       @relation("AppointmentOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  treating_physician User? @relation("AppointmentTreatingPhysician", fields: [treating_physician_id], references: [id], onDelete: SetNull)
  assignees   AppointmentAssignee[]
  activities  Activity[]

  @@index([treating_physician_id])
  @@map("appointments")
}

// --- Appointment Assignee (DB: appointment, "user", invited_by)
model AppointmentAssignee {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime @default(now())
  appointment_id    String   @map("appointment") @db.Uuid
  user_id           String?  @map("user") @db.Uuid
  user_type         String?  @db.Text // 'relatives' | 'patients'
  invited_email     String?  @db.Text
  status            String?  @db.Text // 'pending' | 'accepted' | 'declined'
  invitation_token  String?  @unique @db.Uuid
  permission        String?  @db.Text // 'read' | 'write' | 'full'
  invited_by_id     String?  @map("invited_by") @db.Uuid

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  user        User?      @relation("AssigneeUser", fields: [user_id], references: [id], onDelete: SetNull)
  invited_by  User?      @relation("AssigneeInvitedBy", fields: [invited_by_id], references: [id], onDelete: SetNull)

  @@map("appointment_assignee")
}

// --- Activities (DB: created_by, appointment)
model Activity {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at     DateTime @default(now())
  created_by_id  String?  @map("created_by") @db.Uuid
  appointment_id String   @map("appointment") @db.Uuid
  type           String   @db.Text
  content        String   @db.Text

  created_by  User?       @relation("ActivityCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)

  @@map("activities")
}

// --- Scheduling (weekly availability, time off, event types)
model DoctorAvailability {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id   String @db.Uuid
  weekday   Int // 0 = Sunday … 6 = Saturday (Date.getDay)
  start_min Int // minutes from midnight (0–1439) in `timezone`
  end_min   Int
  timezone  String @db.Text // IANA e.g. Europe/Berlin

  user User @relation("DoctorAvailabilityUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, weekday])
  @@map("doctor_availability")
}

model DoctorTimeOff {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id   String   @db.Uuid
  starts_at DateTime @db.Timestamptz(6)
  ends_at   DateTime @db.Timestamptz(6)
  reason    String?  @db.Text

  user User @relation("DoctorTimeOffUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, starts_at])
  @@map("doctor_time_off")
}

model AppointmentType {
  id                     String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at             DateTime @default(now())
  user_id                String?  @db.Uuid
  name                   String   @db.Text
  /// Short description shown on the services page
  description            String?  @db.Text
  duration_minutes       Int
  buffer_before_minutes  Int      @default(0)
  buffer_after_minutes   Int      @default(0)
  slot_interval_minutes  Int      @default(30)
  minimum_notice_minutes Int      @default(60)

  user User? @relation("AppointmentTypeUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("appointment_types")
}

// --- Dashboard Access (DB: invited_by)
model DashboardAccess {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime @default(now())
  owner_user_id     String   @db.Uuid
  invited_user_id   String?  @db.Uuid
  invited_email     String?  @db.Text
  status            String?  @db.Text // 'pending' | 'accepted' | 'declined'
  invitation_token  String?  @unique @db.Uuid
  permission        String?  @db.Text // 'read' | 'write' | 'full'
  invited_by_id     String?  @map("invited_by") @db.Uuid

  owner_user   User  @relation("DashboardOwner", fields: [owner_user_id], references: [id], onDelete: Cascade)
  invited_user User? @relation("DashboardInvitedUser", fields: [invited_user_id], references: [id], onDelete: SetNull)
  invited_by   User? @relation("DashboardInvitedBy", fields: [invited_by_id], references: [id], onDelete: SetNull)

  @@map("dashboard_access")
}

// --- Notifications (in-app notification center)
model Notification {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at DateTime @default(now())
  user_id    String   @db.Uuid
  title      String   @db.Text
  message    String   @db.Text
  type       String   @db.Text // 'info' | 'success' | 'warning' | 'error' | 'invitation' | 'reminder'
  read       Boolean  @default(false)
  link       String?  @db.Text // optional link to navigate to

  user User @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read])
  @@index([user_id, created_at])
  @@map("notifications")
}

// --- Google Calendar Token (OAuth token storage for calendar sync)
model GoogleCalendarToken {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime? @db.Timestamptz(6)
  user_id       String   @unique @db.Uuid
  access_token  String   @db.Text
  refresh_token String?  @db.Text
  expiry_date   DateTime? @db.Timestamptz(6)
  calendar_id   String?  @db.Text // user's primary calendar ID

  user User @relation("UserGoogleCalendar", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("google_calendar_tokens")
}

// --- Organization (multi-tenant support)
model Organization {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at    DateTime @default(now())
  name          String   @db.Text
  slug          String   @unique @db.Text
  owner_user_id String   @db.Uuid
  description   String?  @db.Text
  website       String?  @db.Text
  address       String?  @db.Text
  phone         String?  @db.Text

  members OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id    String   @db.Uuid
  user_id   String   @db.Uuid
  role      String   @db.Text // 'admin' | 'doctor' | 'secretary' | 'patient'
  joined_at DateTime @default(now())

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@unique([org_id, user_id])
  @@map("organization_members")
}

// --- Invoices & Payments (billing)
model Invoice {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at     DateTime  @default(now())
  appointment_id String?   @db.Uuid
  user_id        String    @db.Uuid
  amount         Int       // Amount in cents
  currency       String    @default("eur") @db.Text
  status         String    @default("draft") @db.Text // 'draft' | 'sent' | 'paid' | 'overdue' | 'cancelled'
  due_date       DateTime? @db.Date
  paid_at        DateTime? @db.Timestamptz(6)
  description    String?   @db.Text

  payments Payment[]

  @@map("invoices")
}

model Payment {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime @default(now())
  invoice_id        String   @db.Uuid
  stripe_payment_id String?  @db.Text
  amount            Int      // Amount in cents
  status            String   @db.Text // 'pending' | 'succeeded' | 'failed' | 'refunded'

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("payments")
}